  allowed_widget_patterns [timeline_view activity_feed audit_log]
  related_terms [term_status_update]
  domain dom_operations_ui_work_map
  status active
}

region region_assignment_board {
  name "Assignment Board"
  description "Board-style region for reviewing work grouped by assignee and capacity."
